CREATE TABLE Students (
    Id INT PRIMARY KEY IDENTITY,
    FullName NVARCHAR(100),
    Age INT
);

CREATE TABLE Teachers (
    Id INT PRIMARY KEY IDENTITY,
    FullName NVARCHAR(100),
    Salary DECIMAL(10,2)
);

CREATE TABLE Courses (
    Id INT PRIMARY KEY IDENTITY,
    CourseName NVARCHAR(100),
    Price DECIMAL(10,2)
);
